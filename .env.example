# ---- Runtime ----
NODE_ENV=development
PORT=4001
SERVICE_NAME=auth-service
LOG_LEVEL=debug

# ---- Database (auth owns its own DB) ----
DATABASE_URL=postgresql://vaultpay:vaultpay@localhost:5432/vaultpay_auth?schema=public

# ---- Redis (sessions, refresh deny-list, rate-limit, oauth state, mfa challenge) ----
REDIS_URL=redis://localhost:6379

# ---- JWT (customer) ----
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ---- Admin session ----
SESSION_SECRET=change-me-session
SESSION_TTL_SECONDS=3600
SESSION_COOKIE_NAME=vaultpay_admin_sid

# ---- Service-to-service (S2S) ----
S2S_SECRET=change-me-s2s
S2S_TOKEN_TTL=60s

# ---- Encryption middleware toggle ----
ENCRYPTION_ENABLED=false
ENCRYPTION_KEY=change-me-32-byte-key-000000000000

# ---- MFA (TOTP) ----
MFA_ISSUER=VaultPay

# ---- OAuth (free providers) ----
OAUTH_REDIRECT_BASE_URL=http://localhost:4001/auth/oauth
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# ---- Email (Mailtrap + Nodemailer) ----
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=
MAIL_FROM="VaultPay <no-reply@vaultpay.local>"

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX=100

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000

# ---- Cluster ----
CLUSTER_ENABLED=false
CLUSTER_WORKERS=0
